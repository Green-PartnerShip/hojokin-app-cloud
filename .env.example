PORT=39200
HOST=0.0.0.0

# Optional: add comma-separated client IPs if your company network uses
# non-private addresses that are blocked by the default LAN-only guard.
ALLOWED_CLIENTS=

# Keep off unless debugging locally. When enabled, upstream API details
# may be returned in error responses.
DEBUG_ERRORS=0

# AI API keys are intentionally unused in this browser-based version.

# Cloud/public deployment.
# Turn this on only when deploying behind HTTPS on a cloud platform.
CLOUD_MODE=0
PUBLIC_ACCESS=0
AUTH_REQUIRED=0
# Set this only in the cloud provider's secret/environment settings.
APP_PASSWORD=
# SESSION_SECRET must be 32+ random characters when auth is enabled.
SESSION_SECRET=
SESSION_TTL_HOURS=12

# Shared database for the cloud version.
# Render sets this automatically from the Postgres database.
DATABASE_URL=
# Set to 1 only when your database URL requires SSL.
DATABASE_SSL=0

# Optional local fallback path for hearing-sheet shared data.
HEARING_DATA_DIR=
